<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Standard bundle identity keys (previously auto-generated by Xcode).
         $(VARIABLE) tokens are substituted by the build system from build settings.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleDisplayName</key>
    <string>ClinicalAI</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Allowed URL query schemes — required by iOS for the app to check whether
         the Meta AI companion app is installed (canOpenURL). The SDK calls this
         internally as part of startRegistration(). Without this entry, iOS silently
         blocks the query on iOS 9+ and registration will fail.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>fb-viewapp</string>
    </array>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Deep-link URL scheme — required by MWDAT for the Meta AI app registration
         callback. The Meta AI app redirects to clinicalai:// after the physician
         completes glasses pairing. Wearables.shared.handleUrl(_:) processes the URL.

         The scheme here must exactly match AppLinkURLScheme in the MWDAT dict below.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>clinicalai</string>
            </array>
        </dict>
    </array>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Meta Wearables Device Access Toolkit (MWDAT) configuration.

         MetaAppID and ClientToken are supplied via Build Settings user-defined
         variables (META_APP_ID, CLIENT_TOKEN) so they never appear as literals
         in source code. Add them in Xcode → Project → Build Settings → + → Add
         User-Defined Setting:
             META_APP_ID   = <your Meta app ID>
             CLIENT_TOKEN  = <your client token>

         TeamID must match the Apple Developer Team ID of the signing certificate.
         It is read from DEVELOPMENT_TEAM which Xcode sets automatically.

         DAMEnabled enables the Device Access Manager, required for camera access.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>MWDAT</key>
    <dict>
        <key>AppLinkURLScheme</key>
        <string>clinicalai://</string>
        <key>MetaAppID</key>
        <string>$(META_APP_ID)</string>
        <key>ClientToken</key>
        <string>$(CLIENT_TOKEN)</string>
        <key>TeamID</key>
        <string>$(DEVELOPMENT_TEAM)</string>
        <key>DAMEnabled</key>
        <true/>
    </dict>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         External accessory protocol — declares that this app communicates with
         accessories using the Meta wearable protocol over the Lightning/USB connector.
         Required for App Store submission and for MFi accessory communication.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>UISupportedExternalAccessoryProtocols</key>
    <array>
        <string>com.meta.ar.wearable</string>
    </array>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Background modes — allows the app to maintain the glasses connection and
         receive audio while in the background (e.g., when the physician's screen
         locks during a long encounter).
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
        <string>external-accessory</string>
    </array>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         Privacy usage descriptions — shown to the physician the first time the app
         requests each permission. iOS rejects the permission request without these.
    ═══════════════════════════════════════════════════════════════════════════════ -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ClinicalAI uses Bluetooth to connect to your Meta AI glasses for audio capture and photo capture during patient encounters.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>ClinicalAI records audio through your glasses microphone during patient encounters to generate clinical documentation.</string>

    <!-- NSCameraUsageDescription is required by MWDAT even though the camera is on
         the glasses, not the iPhone. The SDK requests this permission on behalf of
         the wearable camera stream. -->
    <key>NSCameraUsageDescription</key>
    <string>ClinicalAI accesses the camera on your Meta AI glasses to capture physical exam findings during patient encounters.</string>

    <!-- ═══════════════════════════════════════════════════════════════════════════
         UI configuration keys (previously auto-generated by Xcode via
         INFOPLIST_KEY_UIApplicationSceneManifest_Generation and related settings).
    ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- SwiftUI WindowGroup apps use a single scene with no storyboard configuration. -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>

    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- Empty UILaunchScreen dict → default white launch screen (no storyboard needed). -->
    <key>UILaunchScreen</key>
    <dict/>

    <!-- iPhone: portrait + both landscape orientations. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- iPad: all four orientations. -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

</dict>
</plist>
