// Secrets.xcconfig.example
// ClinicalAI — Meta Wearables SDK credentials template
//
// This file IS tracked by git. It is a template only — it contains no real secrets.
//
// Setup:
//   1. Copy this file to Secrets.xcconfig (same directory)
//   2. Fill in your real values from:
//      https://developers.facebook.com/apps/<YOUR_APP_ID>/settings/basic/
//   3. Secrets.xcconfig is git-ignored so your credentials stay local.

META_APP_ID = YOUR_META_APP_ID_HERE
CLIENT_TOKEN = YOUR_CLIENT_TOKEN_HERE
